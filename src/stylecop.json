{
  "settings": {
    "documentationRules": {
      "xmlHeader": false,
      "documentInterfaces": false,
      "documentInternalElements": false
    },
    "indentation": {
      "indentationSize": 4,
      "useTabs": false
    },
    "layoutRules": {
      "newlineAtEndOfFile": "require"
    },
    "orderingRules": {
      "systemUsingDirectivesFirst": true,
      "usingDirectivesPlacement": "outsideNamespace"
    }
  }
}
